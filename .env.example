# Copy this file to .env and fill in your real values.
# .env is git-ignored — never commit real credentials.

# Your StatCounter account username
STATCOUNTER_USERNAME=your_username

# The API password you set in your StatCounter account settings.
# This is NOT your login password — it's the dedicated API password.
# Requires a paid StatCounter account with the API enabled.
STATCOUNTER_API_PASSWORD=your_api_password
